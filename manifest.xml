<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<!--
  ─────────────────────────────────────────────────────────────────────
  NCC Email Signature Client — manifest.xml
  Version 1.2.5.0  (Nested App Authentication, no backend)
  ─────────────────────────────────────────────────────────────────────

  Diagnostic history
    v1.0.5.0 (no SSO)             → uploaded ✓
    v1.2.1.0 (SSO + extras)       → 400 Sideloading rejected
    v1.2.2.0 (stripped SSO)       → 400 Sideloading rejected
                                    + 403 on Graph meProvisioningInfo
    v1.2.3.0 (domain-prefixed
              Resource URI)        → uploaded ✓ but Graph 401'd because
                                    SSO tokens are audience'd to our API,
                                    not Graph
    v1.2.4.0 (Azure Function
              OBO backend)         → built but not deployed; archived
                                    under future-backend/ in case we
                                    need it later
    v1.2.5.0 (this)               → switches to Nested App Authentication.
                                    MSAL.js inside the taskpane handles
                                    the OBO swap client-side via Microsoft's
                                    auth backend — no server, no client
                                    secret, no extra AppDomains needed.

  Resource URI format
    api://harrisonblackncc.github.io/55e5528d-7efd-4bd5-a437-0d31c68d3542
-->
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>ee5c20d5-aa7d-4462-a9a8-0a39ac4ea746</Id>
  <Version>1.2.5.0</Version>
  <ProviderName>Nambour Christian College</ProviderName>
  <DefaultLocale>en-AU</DefaultLocale>
  <DisplayName DefaultValue="NCC Email Signature Client"/>
  <Description DefaultValue="Inserts your NCC branded email signature."/>
  <IconUrl DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/icon-128.png"/>
  <SupportUrl DefaultValue="https://www.ncc.qld.edu.au"/>

  <AppDomains>
    <AppDomain>https://harrisonblackncc.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/taskpane.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox"/>
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="ncc.signature.group">
                <Label resid="GroupLabel"/>
                <Control xsi:type="Button" id="ncc.signature.button">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Taskpane.Url" DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="NCC Signature"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Signature"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open to customise your NCC email signature."/>
      </bt:LongStrings>
    </Resources>

    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.5">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="ncc.signature.group">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="ncc.signature.button">
                    <Label resid="TaskpaneButton.Label"/>
                    <Supertip>
                      <Title resid="TaskpaneButton.Label"/>
                      <Description resid="TaskpaneButton.Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/icon-16.png"/>
          <bt:Image id="Icon.32x32" DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/icon-32.png"/>
          <bt:Image id="Icon.80x80" DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Taskpane.Url" DefaultValue="https://harrisonblackncc.github.io/ncc-emailsig-poc/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="NCC Signature"/>
          <bt:String id="TaskpaneButton.Label" DefaultValue="Signature"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open to customise your NCC email signature."/>
        </bt:LongStrings>
      </Resources>

      <WebApplicationInfo>
        <Id>55e5528d-7efd-4bd5-a437-0d31c68d3542</Id>
        <Resource>api://harrisonblackncc.github.io/55e5528d-7efd-4bd5-a437-0d31c68d3542</Resource>
        <Scopes>
          <Scope>User.Read</Scope>
          <Scope>profile</Scope>
          <Scope>openid</Scope>
        </Scopes>
      </WebApplicationInfo>
    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
